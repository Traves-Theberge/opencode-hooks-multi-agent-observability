{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teammateMode": "in-process",
  "statusLine": {
    "type": "command",
    "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/status_lines/status_line_v6.ts",
    "padding": 0
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/pre_tool_use.ts"
          },
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/send_event.ts --source-app opencode-hook-multi-agent-obvs --event-type PreToolUse --summarize"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/post_tool_use.ts"
          },
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/send_event.ts --source-app opencode-hook-multi-agent-obvs --event-type PostToolUse --summarize"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/notification.ts"
          },
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/send_event.ts --source-app opencode-hook-multi-agent-obvs --event-type Notification --summarize"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/stop.ts --chat"
          },
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/send_event.ts --source-app opencode-hook-multi-agent-obvs --event-type Stop --add-chat"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/subagent_stop.ts"
          },
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/send_event.ts --source-app opencode-hook-multi-agent-obvs --event-type SubagentStop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/pre_compact.ts"
          },
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/send_event.ts --source-app opencode-hook-multi-agent-obvs --event-type PreCompact"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/user_prompt_submit.ts --log-only --store-last-prompt --name-agent"
          },
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/send_event.ts --source-app opencode-hook-multi-agent-obvs --event-type UserPromptSubmit --summarize"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/session_start.ts"
          },
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/send_event.ts --source-app opencode-hook-multi-agent-obvs --event-type SessionStart"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/session_end.ts"
          },
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/send_event.ts --source-app opencode-hook-multi-agent-obvs --event-type SessionEnd"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/permission_request.ts"
          },
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/send_event.ts --source-app opencode-hook-multi-agent-obvs --event-type PermissionRequest --summarize"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/post_tool_use_failure.ts"
          },
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/send_event.ts --source-app opencode-hook-multi-agent-obvs --event-type PostToolUseFailure --summarize"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/subagent_start.ts"
          },
          {
            "type": "command",
            "command": "bun run $OPENCODE_PROJECT_DIR/.opencode/hooks/send_event.ts --source-app opencode-hook-multi-agent-obvs --event-type SubagentStart"
          }
        ]
      }
    ]
  }
}