{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run .opencode/hooks/pre_tool_use.ts"
          },
          {
            "type": "command",
            "command": "bun run .opencode/hooks/send_event.ts --source-app demo-agent --event-type PreToolUse --summarize"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run .opencode/hooks/post_tool_use.ts"
          },
          {
            "type": "command",
            "command": "bun run .opencode/hooks/send_event.ts --source-app demo-agent --event-type PostToolUse --summarize"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run .opencode/hooks/notification.ts --notify "
          },
          {
            "type": "command",
            "command": "bun run .opencode/hooks/send_event.ts --source-app demo-agent --event-type Notification --summarize"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run .opencode/hooks/stop.ts --chat"
          },
          {
            "type": "command",
            "command": "bun run .opencode/hooks/send_event.ts --source-app demo-agent --event-type Stop --add-chat"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run .opencode/hooks/subagent_stop.ts"
          },
          {
            "type": "command",
            "command": "bun run .opencode/hooks/send_event.ts --source-app demo-agent --event-type SubagentStop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run .opencode/hooks/send_event.ts --source-app demo-agent --event-type PreCompact"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run .opencode/hooks/user_prompt_submit.ts --log-only"
          },
          {
            "type": "command",
            "command": "bun run .opencode/hooks/send_event.ts --source-app demo-agent --event-type UserPromptSubmit --summarize"
          }
        ]
      }
    ]
  }
}